generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cards     Card[]
}

model Card {
  id             String    @id @default(cuid())
  userId         String
  templateId     String?
  name           String
  designation    String?
  company        String?
  qualification  String?
  coverImage     String?
  clinicTiming   String?
  galleryImages  String[] @default([])
  services       Json?
  products       Json?
  paymentLinks   Json? 
  socialLinks    Json? 
  testimonials   Json? 
  documents      Json?
  showServices   Boolean @default(true)
  showProducts   Boolean @default(true)
  specialization String?
  appointmentUrl String?
  mobile         String?
  whatsapp       String?
  email          String?
  website        String?
  bio            String?
  profileImage   String?
  slug           String    @unique
  views          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  facebook       String?
  instagram      String?
  linkedin       String?
  telegram       String?
  twitter        String?
  youtube        String?
  address        String?
  aboutUs        String?
  primaryColor   String?   @default("#2563eb")
  secondaryColor String?   @default("#ffffff")
  fontFamily     String?   @default("Inter")
  buttonStyle    String?   @default("rounded")
  directionUrl   String?
  paymentQrCode  String?
  upiId          String?
  template       Template? @relation(fields: [templateId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads          Lead[]
  showQrSection  Boolean  @default(true)
  
}

model Lead {
  id        String   @id @default(cuid())
  cardId    String
  name      String
  email     String?
  mobile    String?
  message   String?
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id         String   @id @default(cuid())
  name       String
  price      Float
  cardsLimit Int
  createdAt  DateTime @default(now())
}

model Commission {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model Product {
  id          String @id
  name        String
  image       String?
}


model Template {
  id        String   @id @default(cuid())
  name      String
  thumbnail String?
  createdAt DateTime @default(now())
  category  String
  isActive  Boolean  @default(true)
  slug      String   @unique
  cards     Card[]
}

enum UserRole {
  USER
  ADMIN
  RESELLER
  SUPER_ADMIN
}
