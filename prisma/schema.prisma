generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ================= USER =================
 */

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(USER)

  isActive      Boolean @default(true)
  emailVerified Boolean @default(false)

  createdAt DateTime @default(now())

  cards         Card[]
  subscription  Subscription?
  reseller      Reseller?
  payments      Payment[]
}

/**
 * ================= CARD =================
 */

model Card {
  id         String  @id @default(cuid())
  userId     String
  templateId String?

  name          String
  designation   String?
  company       String?
  qualification String?

  coverImage   String?
  clinicTiming String?

  galleryImages String[] @default([])

  services     Json?
  products     Json?
  paymentLinks Json?
  socialLinks  Json?
  testimonials Json?
  documents    Json?

  showServices Boolean @default(true)
  showProducts Boolean @default(true)

  specialization String?
  appointmentUrl String?

  mobile   String?
  whatsapp String?
  email    String?
  website  String?

  bio          String?
  profileImage String?

  slug  String @unique
  views Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facebook  String?
  instagram String?
  linkedin  String?
  telegram  String?
  twitter   String?
  youtube   String?

  address String?
  aboutUs String?

  primaryColor   String? @default("#2563eb")
  secondaryColor String? @default("#ffffff")
  fontFamily     String? @default("Inter")
  buttonStyle    String? @default("rounded")

  directionUrl  String?
  paymentQrCode String?
  upiId         String?

  showQrSection Boolean @default(true)

  template Template? @relation(fields: [templateId], references: [id])
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads    Lead[]
}

/**
 * ================= LEAD =================
 */

model Lead {
  id     String @id @default(cuid())
  cardId String

  name    String
  email   String?
  mobile  String?
  message String?

  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

/**
 * ================= SUBSCRIPTION =================
 */

model Subscription {
  id     String @id @default(cuid())
  userId String @unique

  plan   String
  status String

  cardLimit Int @default(1)
  extraCards Int @default(0)

  customDomain Boolean @default(false)

  razorpayPaymentId String?
  razorpayOrderId   String?

  startDate DateTime
  expiryDate DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * ================= PAYMENT =================
 */
 model Payment {
  id String @id @default(cuid())
  userId String
  amount Float
  plan String
  status PaymentStatus @default(PENDING)

  razorpayOrderId String?
  razorpayPaymentId String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
/**
 * ================= COMMISSION =================
 */

model Commission {
  id     String @id @default(cuid())
  userId String

  amount Float

  status String @default("PENDING")

  createdAt DateTime @default(now())
}

/**
 * ================= PRODUCT =================
 */

model Product {
  id    String @id @default(cuid())
  name  String
  image String?
}

/**
 * ================= TEMPLATE =================
 */

model Template {
  id        String @id @default(cuid())
  name      String
  thumbnail String?
  category  String
  slug      String @unique
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())

  cards Card[]
}

/**
 * ================= RESELLER =================
 */

model Reseller {
  id     String @id @default(cuid())
  userId String @unique

  companyName String
  commission  Float @default(0)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * ================= ENUM =================
 */

enum UserRole {
  USER
  ADMIN
  RESELLER
  SUPER_ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

